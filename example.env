# Application
PORT=3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/roaspig-nest-be
MONGODB_DB_NAME=roaspig-db

# Authentication (JWT)
JWT_SECRET=change_me

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/redirect

# Google Cloud Storage
GCS_BUCKET_NAME=your_bucket_name
# Option 1: Path to key file
GCS_KEY_FILENAME=path/to/your/keyfile.json
# Option 2: JSON credentials as string
GCS_CREDENTIALS=

# Mailer (Resend)
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM="Freight Team <noreply@yourdomain.com>"

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
